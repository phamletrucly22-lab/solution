DATABASE_URL="postgresql://postgres:postgres@localhost:5433/tosino?schema=public"
JWT_SECRET="change-me-in-production-use-long-random"
JWT_REFRESH_SECRET="change-me-refresh-secret"
API_PORT=4001
PUBLIC_API_URL="https://apisgate.org"
REDIS_URL="redis://127.0.0.1:6379"
# OddsHost 권장(프리매치·스냅샷)과 맞춤: 약 2분마다 전 플랫폼 ODDS 동기화 + sports-live 수집 (Redis 필요)
ODDS_SYNC_CRON="*/2 * * * *"
# production 에서도 기동 직후 카탈로그 스냅샷 1회 (비우면 운영 프로필에선 끔)
RUN_ODDS_INGEST_ON_BOOT=1
# 기동 1회 크롤 매칭(첫 ODDS 스냅샷 직후 큐잉). 끄려면 0
RUN_CRAWLER_MATCHER_ON_BOOT=1
PAYMENT_WEBHOOK_SECRET="shared-secret-with-payment-server"
# Vinus 콜백/런처 테스트 (play-game 호출 시 에이전트 키는 실제 값 권장)
VINUS_AGENT_KEY="ta125"
VINUS_AUTH_KEY="local-test-callback-auth"
# 벤더 authenticate 테스트용 (운영 전 false 로)
VINUS_STUB_AUTHENTICATE=true

# ── OddsHost 스포츠 (GET /api/public/oddshost/*)
#
# ODDSHOST_PROXY_SECRET
#   벤더 인증키와 무관. “우리 API 프록시 잠금 비밀번호”를 직접 하나 정한 값입니다.
#   솔루션 웹 → 인플레이/프리매치 → API 테스트 탭의 oddshostSecret 입력란에도 동일 문자열을 넣어야 호출됩니다.
#   (아래 값은 예시로 생성해 둠. 운영에서 바꾸면 웹 입력값도 같이 바꾸세요.)
ODDSHOST_PROXY_SECRET=23bee2b7dfe7d735cbe286032339c206d5ff12b11db2ffc5e025632b74744fae
#
# ODDSHOST_KEY
#   오즈호스트가 메일로 준 인증키 한 줄. 레포에 실키 커밋하지 말 것 — 서버/CI 시크릿에만 넣기.
ODDSHOST_KEY=e76efa15-97ed
#
# URL: TEMPLATE_* 전체 URL 한 줄이 있으면 ODDSHOST_BASE_URL + PATH_* 보다 우선합니다.
# 플레이스홀더: {key} {sport} {game_id} {date}(yyyymmdd, 서울 당일 또는 ODDSHOST_QUERY_DATE)
# ODDSHOST_QUERY_DATE=
ODDSHOST_BASE_URL=https://api.oddshost.com
ODDSHOST_PATH_INPLAY_LIST=
ODDSHOST_PATH_INPLAY_GAME=
ODDSHOST_PATH_PREMATCH=
ODDSHOST_PATH_MARKETS=
ODDSHOST_TEMPLATE_INPLAY_LIST=https://api.oddshost.com/inplay/1xb/?token={key}&sport={sport}
ODDSHOST_TEMPLATE_INPLAY_GAME=https://api.oddshost.com/inplay/1xb/?token={key}&sport={sport}&game_id={game_id}
ODDSHOST_TEMPLATE_PREMATCH=https://api.oddshost.com/prematch/1xb/?token={key}&sport={sport}&date={date}
ODDSHOST_TEMPLATE_MARKETS=https://api.oddshost.com/markets/1xb/?token={key}&sport={sport}&date={date}
# odds-api.io 만 쓰면 false (OddsHost 인플레이 → sports-live 끔)
ODDSHOST_SPORTS_LIVE_INGEST=false
ODDSHOST_INGEST_SPORT=1

# ── odds-api.io WebSocket (실시간 배당) ─────────────────────────────────
# 가이드: https://docs.odds-api.io/guides/websocket
# ODDS_API_KEY 만 채우면 자동 연결. 종목·마켓은 슈퍼어드민 콘솔(/console/odds-api-ws)에서 변경.
ODDS_API_KEY=2fc43f31299b00a05a55929dab3ce18216f701eb49632d88f0108bb93ce2c583
# REST(스냅샷) 슬라이딩: 대시 5000/h 쿼터 → 4000/h 목표. 분/시 양쪽이 동시에 맞을 때만 송신
ODDS_API_MAX_REQUESTS_PER_HOUR=4000
# 동시에 구독·REST 카탈로그(아래 CATALOG 생략 시 WS 와 동일) 종목 슬러그
ODDS_API_WS_SPORTS=football,baseball,basketball,volleyball,ice-hockey,american-football,tennis,esports
# REST 스냅샷 sports 강제(우선). 비우면 ODDS_API_WS_SPORTS, 둘 다 비우면 플랫폼 DB
# ODDS_API_CATALOG_SPORTS=football,baseball,basketball,volleyball,ice-hockey,american-football,tennis,esports
# 마켓 (필수, 콤마구분, 최대 20개) — 현재 확인된 축구 전 마켓 수신
# ML=승/무/패, Spread=아시안핸디캡, Totals=언오버, DNB=무승부취소, DC=더블찬스,
# BTTS=양팀득점여부, EH=유러피언핸디캡(정수핸디), HTFT=전반/전체 결과 조합
ODDS_API_WS_MARKETS=ML,Spread,Totals,Draw No Bet,Double Chance,Both Teams To Score,European Handicap,Half Time / Full Time
# (선택) 'live' 또는 'prematch' — 비우면 둘 다
ODDS_API_WS_STATUS=
# (선택) WS 수신 북메이커 화이트리스트. 비우면 전체.
ODDS_API_WS_BOOKMAKERS=1xbet,Sbobet,Bet365,22Bet,GG.bet
# 부팅 시 자동 연결 여부. false 면 콘솔에서 수동 연결.
ODDS_API_WS_AUTOCONNECT=true
# ── odds-api display whitelist 크롤러 인증 키 (콤마 구분; M2M 용) ───────────
ODDS_API_INTEGRATION_KEYS=local-score-crawler-dev-key

# ── USDT 온체인 입금 감지 (TronGrid TRC20) ───────────────────────────────
# TronGrid API 키 (https://www.trongrid.io 에서 발급)
TRONGRID_API_KEY=79639b24-1c41-4d54-9049-c55348be7445
# 폴링 주기 크론 (기본 1분; 비활성화: disabled)
USDT_DEPOSIT_POLL_CRON=*/1 * * * *
