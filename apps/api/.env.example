# PM2(ecosystem.config.js)는 cwd=apps/api 로 기동 → 이 파일이 로드됩니다.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/tosino?schema=public"
# prisma db seed 시 데모 플랫폼 sports-live / sports-prematch 를 채움(비어 있을 때만). 기존 덮어쓰기: SEED_FORCE_SPORTS_SNAPSHOTS=1
# SEED_FORCE_SPORTS_SNAPSHOTS=
JWT_SECRET="change-me-in-production-use-long-random"
JWT_REFRESH_SECRET="change-me-refresh-secret"
API_PORT=4001
# nginx 등 리버스 프록시 1대 기본값 1. 여러 단이면 그만큼 숫자 증가
# TRUST_PROXY_HOPS=1
# 브라우저에서 /uploads 이미지·웹훅 URL 등 (접두사 /api 없음; /webhooks, /uploads 는 루트)
PUBLIC_API_URL="http://localhost:4001"
# 운영 예 (nginx apex): 공개 URL 은 스킴+호스트만, /api 붙이지 않음
# PUBLIC_API_URL="https://nexus001.vip"
# 프론트: apps/*/.env.production 에 NEXT_PUBLIC_API_URL=https://nexus001.vip/api
# 로컬 dev: NEXT_PUBLIC_API_URL=http://localhost:4001/api
# 공개 bootstrap ?host= 매칭: demo 플랫폼에 도메인이 있어야 함. 비어 있으면 404.
# SEED_PLATFORM_HOSTS=nexus001.vip,www.nexus001.vip
# 솔루션 어드민 전용 호스트 → 플랫폼 slug (로그인 시 host 로 플랫폼 결정). 코드 기본: mod.i-on.bet → demo
# 추가·덮어쓰기: SOLUTION_ADMIN_BIND_HOSTS=mod.client.com:acme
# SOLUTION_ADMIN_BIND_HOSTS=
# 솔루션 공지 팝업(부트스트랩). 기본 켜짐. 끄려면 false
# ANNOUNCEMENT_MODAL_PUBLISH=true
# 업로드 디렉터리 (기본: apps/api/uploads)
# UPLOAD_DIR="/var/tosino/uploads"
REDIS_URL="redis://127.0.0.1:6379"

# ── Bull 과부하 큐 (sync / usdt-deposit / comp-settlement) ─────────────
# 운영 pm2: API 에 BULL_WORKERS_IN_API=0 + sync-worker / usdt-deposit-worker / comp-settlement-worker.
# 한 PC에서 프로세스 줄이려면: pnpm start:bull-heavy-worker (TOSINO_PROCESS_ROLE=bull-heavy-worker 통합).
# 로컬 단일 `pnpm dev:api` 는 env 비우면 API 안에서 그대로 소비(기본).
# BULL_WORKERS_IN_API=0
# 로컬 .env 를 운영과 맞추며 NODE_ENV=production 을 쓰는 경우, 주기 ODDS·기동 ingest·크롤 매처 기동을 “개발 기본”으로 유지하려면 1.
# 운영 서버(ecosystem)에는 두지 말 것 — 두면 주기 ODDS·기동 잡이 개발 기본처럼 켜져 부하·정책이 달라질 수 있음.
# TOSINO_LOCAL_SCHEDULERS=1
# 주기 ODDS 스냅샷 (모든 플랫폼). off/false/0/disabled 이면 비활성. Bull repeat cron (5필드, 분 단위).
# 개발 스케줄 프로필(NODE_ENV≠production 또는 TOSINO_LOCAL_SCHEDULERS=1)이고 여기 비우면 기본 */2 * * * * (2분마다). 운영 프로필에서 비우면 주기 없음.
# OddsHost 가이드 권장(프리매치 1~2분)에 맞춘 예: 2분마다
# ODDS_SYNC_CRON="*/2 * * * *"
# 1분마다: ODDS_SYNC_CRON="* * * * *"
# API 기동 직후 전 플랫폼 ODDS ingest 1회 큐 (비프로덕션 기본 on). 끄기: RUN_ODDS_INGEST_ON_BOOT=0
# production 에서만 켜기: RUN_ODDS_INGEST_ON_BOOT=1
# RUN_ODDS_INGEST_ON_BOOT=
# 기동 1회 큐 지연(ms). Redis/Prisma 준비 후 돌리기 위함.
# RUN_ODDS_INGEST_ON_BOOT_DELAY_MS=2500
PAYMENT_WEBHOOK_SECRET="shared-secret-with-payment-server"
# 설정 시 ?port= 미리보기 bootstrap/sports-odds 에 동일 값을 previewSecret 로 전달해야 함
# PREVIEW_BOOTSTRAP_SECRET=""
# ── OddsHost 스포츠 API 프록시 (Nest: GET /api/public/oddshost/*)
#     점검: GET /api/public/oddshost/diagnostic?sport=1&oddshostSecret=…  (probe=1 이면 인플레이 목록 URL로 업스트림 GET)
# 벤더는 허용 outbound IP 기준. 이 API 프로세스가 그 IP에서 나가야 함.
# 가이드: https://www.oddshost.com/api-guide
#
# ── 벤더 “테스트 API” 메일 기준 체크리스트 (예시)
#   · 허용 IP = Nest 가 OddsHost 로 나가는 공인 IP(메일에 적힌 값과 동일해야 함). 확인:
#       curl -sSf https://api.ipify.org
#   · 인증키 → ODDSHOST_KEY (메일의 키). ODDSHOST_PROXY_SECRET 과는 별개(후자는 우리가 만든 프록시용 비밀번호).
#   · 테스트 기간(시작~종료일) 밖이면 403 등으로 막힐 수 있음.
#   · 테스트 플랜: 국가/리그/팀 리스트 등 정식 대비 제한 — 응답 필드가 비어 있어도 정상일 수 있음.
#   · IN-PLAY / PRE-MATCH / RESULTS 의 실제 path·query 는 가이드 PDF·메일이 정답. 아래 TEMPLATE_* 또는 PATH_* 에
#     플레이스홀더 {key} {sport} {game_id} 로 넣을 것.
#
# ODDSHOST_PROXY_SECRET (벤더가 주는 “인증키”와 다른 것)
#   우리 서버가 /public/oddshost/* 를 열어둘 때 쓰는 “2차 비밀번호”. openssl rand -hex 32 등으로 임의 생성.
#   솔루션은 GET /public/bootstrap 응답의 oddshostProxySecret 으로 자동 첨부(또는 NEXT_PUBLIC_ODDSHOST_PROXY_SECRET 폴백).
#   미리보기 요청이면 쿼리 previewSecret=PREVIEW_BOOTSTRAP_SECRET 으로 대체 가능.
#   운영(NODE_ENV=production)에서 비우면 프록시 403. 비프로덕션에서 비우면 로컬 테스트용으로만 허용.
#
# ODDSHOST_KEY
#   오즈호스트 플랜 인증키(메일로 받은 값). 커밋하지 말고 배포 시크릿에만 보관.
#
# URL 지정 — 둘 중 하나만 쓰면 됨.
#
# (A) 전체 URL 한 줄: ODDSHOST_TEMPLATE_*
#   벤더 문서: token=[key]&sport=[id]&game_id=[id]&date=[yyyymmdd] → 여기서는 {key}{sport}{game_id}{date} 로 치환
#   스킴은 문서가 http 면 http 로 두어도 됨.
#
# Inplay 라이브 목록(전체): …/inplay/1xb/?token={key}&sport={sport}
# ODDSHOST_TEMPLATE_INPLAY_LIST=http://api.oddshost.com/inplay/1xb/?token={key}&sport={sport}
# Inplay 라이브 게임(한 경기): …/inplay/1xb/?token={key}&sport={sport}&game_id={game_id}
# ODDSHOST_TEMPLATE_INPLAY_GAME=http://api.oddshost.com/inplay/1xb/?token={key}&sport={sport}&game_id={game_id}
# Prematch 베이직(전체·date 필수): …/prematch/1xb/?token={key}&sport={sport}&date={date}
# ODDSHOST_QUERY_DATE=
# ODDSHOST_TEMPLATE_PREMATCH=http://api.oddshost.com/prematch/1xb/?token={key}&sport={sport}&date={date}
# Prematch 스페셜: 위와 동일 URL + 쿼리 special=1 (솔루션 스페셜 탭이 자동 부착, 별도 TEMPLATE 불필요)
# Prematch 프로(한 경기): …/prematch/1xb/?token={key}&sport={sport}&game_id={game_id}
#   → 공개 프록시는 쿼리로 game_id 를 넘기면 URL 에 합쳐짐. 베이직용 템플릿(date)과 동시에 쓰기 어렵다면
#   용도별로 서버 설정을 나누거나 관리자·curl 로 호출 시에만 프로 URL 사용.
# 오즈마켓(마켓 피드 — 가이드 JSON URL). 미설정 시 GET /public/oddshost/markets 는 503
# ODDSHOST_TEMPLATE_MARKETS=http://api.oddshost.com/markets/1xb/?token={key}&sport={sport}&date={date}
# ODDSHOST_PATH_MARKETS=
# 결과 API(선택): https://api.oddshost.com/results/1xb/?token={key}&sport={sport}&date={date}
#
#   인증키·sport·game_id·date 가 들어간 부분을 각각 {key} {sport} {game_id} {date} 로 바꿈.
#
# (B) 호스트 + path: ODDSHOST_BASE_URL + ODDSHOST_PATH_*
#   가이드 URL에서 스킴+호스트만 BASE 에, 나머지 path+query 를 PATH 에 넣고 동일 플레이스홀더 사용.
#   예: BASE=https://api.oddshost.com , PATH=/something/live?sport={sport}&key={key}
#   (실제 path 는 가이드 PDF / 고객 메일이 정답 — 공개 웹에는 전체 경로가 없음)
#
# ODDSHOST_PROXY_SECRET=""
# ODDSHOST_KEY=""
# ODDSHOST_BASE_URL=""
# ODDSHOST_PATH_INPLAY_LIST=""
# ODDSHOST_PATH_INPLAY_GAME=""
# ODDSHOST_PATH_PREMATCH=""
# ODDSHOST_TEMPLATE_INPLAY_LIST=""
# ODDSHOST_TEMPLATE_INPLAY_GAME=""
# ODDSHOST_TEMPLATE_PREMATCH=""
# ODDSHOST_TEMPLATE_MARKETS=""
# ODDS 동기화 시 OddsHost 인플레이 → sports-live( OddsHost 쓸 때만 1; odds-api.io 만 쓰면 0 / 비우기·기본 false)
# ODDSHOST_SPORTS_LIVE_INGEST=0
# ODDSHOST_INGEST_SPORT=1
# Vinus Gaming 라이브카지노 (5자 에이전트 키; 콜백은 authKey 검증 안 함)
# VINUS_AGENT_KEY=""
# 테스트: authenticate·balance·bet·bet-win·win·win-add·cancel 만 스텁(메모리).
# sports-reserve / sports-order / sports-confirm / sports-bet / sports-bet-change / sports-win 은
# 항상 DB(원장·CasinoVinusTx·예약)에 저장 — 실연동과 동일 코드 경로.
# 운영에서는 끌 것
# VINUS_STUB_AUTHENTICATE=false
# VINUS_STUB_USER_ID: DB User.id(cuid) 또는 loginId — 스텁 authenticate·check21이 동일한 행을 찾음
# VINUS_STUB_USER_ID="stub-user-dev"
# VINUS_STUB_USERNAME="stub_login"
# VINUS_STUB_NICKNAME="StubUser"
# VINUS_STUB_BALANCE="100000"
# (선택) 로컬 스모크 스크립트가 authKey 헤더를 붙일 때만 사용
# VINUS_AUTH_KEY=""
# VINUS_GAME_BASE_URL="https://game.vinus-gaming.com"
# VINUS_INFO_BASE_URL="https://info.vinus-gaming.com"
# 콜백 등록 URL 예: {PUBLIC_API_URL}/webhooks/vinus
# 로컬에서 벤더 테스트 페이지 쓰려면 cloudflared 로 HTTPS 노출:
#   ./scripts/cloudflared-api-tunnel.sh
# 상세: docs/vinus-callback-tunnel.md
# 관리자 전용 프록시: GET /integrations/vinus/branch-balance, transaction-detail, transaction-history
# 로컬 콜백 스모크: API 기동 후 apps/api 에서
#   pnpm run vinus:callback-smoke   … authenticate 단일
#   pnpm run vinus:flows-smoke      … 심리스(bet→win→confirm) + 트랜스퍼(bet-win transfer Y)

# ── odds-api.io WebSocket (실시간 배당) ─────────────────────────────────
# 가이드: https://docs.odds-api.io/guides/websocket
# 키만 채우면 자동 연결. 종목·마켓은 슈퍼어드민(/console/odds-api-ws) 콘솔에서 갱신 가능.
# REST 스냅샷(카탈로그)은 /v3/odds/multi·단일 /v3/odds 사용. 로그에 getMultiOdds HTTP 403 이면 키·구독(멀티 엔드포인트) 확인.
# 브라우저 URL 은 되는데 서버( Node fetch )만 403 이거든 UA 시도: 아래 켜거나, 크롬 등 UA 로 덮어쓰기.
# ODDS_API_HTTP_USER_AGENT=
# odds-api.io 상한(대시: 5000/시) — 기본 4000/시간(슬라이딩 1h). 분당= floor(시간/60) (명시 시 덮어씀)
# ODDS_API_MAX_REQUESTS_PER_HOUR=4000
# ODDS_API_MAX_REQUESTS_PER_MIN=66
# 카탈 multi 실패 뒤 단일 getOdds 보강: 최대 횟수(기본 28)·호출 사이 ms(기본 450, 429 시 늘리기)
# ODDS_API_CATALOG_GETODDS_FALLBACK_MAX=28
# ODDS_API_CATALOG_GETODDS_FALLBACK_DELAY_MS=450
# ODDS_API_KEY=
# 동시에 구독할 종목 슬러그 (1~10개; 운영 권장 1~2개)
# ODDS_API_WS_SPORTS=football,basketball
# REST 카탈로그 sports 를 플랫폼 DB 대신 이 목록으로(우선). 비우면 ODDS_API_WS_SPORTS, 둘 다 비우면 DB
# ODDS_API_CATALOG_SPORTS=football,baseball,basketball,volleyball,ice-hockey,american-football,tennis,esports
# 마켓(필수, 콤마구분, 최대 20개) — 비우면 ML,Spread,Totals 자동 적용
# ODDS_API_WS_MARKETS=ML,Spread,Totals
# (선택) live | prematch — 비우면 둘 다
# ODDS_API_WS_STATUS=
# (선택) WS 수신 북메이커 화이트리스트. 비우면 전체 수신.
# ODDS_API_WS_BOOKMAKERS=1xbet,Sbobet,Bet365,22Bet,GG.bet
# REST(/v3/odds·events 등) bookmakers 쿼리 — 비우면 위 WS 값과 동일, 둘 다 비우면 플랫폼 DB
# ODDS_API_REST_BOOKMAKERS=1xbet,Sbobet,Bet365,22Bet,GG.bet
# 부팅 시 자동 연결 여부 (false 면 콘솔에서 reconnect 버튼 사용)
# ODDS_API_WS_AUTOCONNECT=true
# 플랫폼 integrationsJson.oddsApi.bookmakers 가 비어 있으면 REST 스냅샷이 0건이 될 수 있음 — 비우면 API /v3/bookmakers/selected 로 자동 채움(Bet365 폴백). 명시 권장: Bet365,SingBet 등
# 크롤러/score M2M ingest 허용 키(콤마 구분). ODDS_API_KEY 와 별개.
# ODDS_API_INTEGRATION_KEYS=your-local-m2m-secret
# 동일 키로 매핑+배당 조회(슈퍼어드민 JWT 없이). platformId=플랫폼 cuid → odds 스냅샷에서 providerOdds(머니라인·핸디 등) 병합.
# GET /api/integrations/crawler/matches/mapping-overlays?sourceSite=aiscore&platformId=<PLATFORM_ID>&sportSlug=football&status=matched&take=50
# 확정 팀/리그의 로컬 `/assets/` 힌트(score-crawler 가 원격 로고 fetch 줄임): GET …/integrations/crawler/asset-hints?sourceSite=aiscore
# 배당 생략: includeOdds=0
# 솔루션(브라우저): GET /api/public/crawler/match-overlays?host=<도메인>&sourceSite=aiscore&sportSlug=football — 목록은 경량 providerOddsPreview + 로고 필드, rawMatch 제외
# 상세(전체 배당): GET /api/public/crawler/match-overlay-detail?host=...&mappingId=<CrawlerMatchMapping.id>

# ── crawler-matcher (Bull 큐 crawler-matcher) ─────────────────────────
# 기본: API(main) 안에서도 스케줄+소비 켬 → `pnpm dev:api` 만으로 매칭 가능. 끄려면 0.
# 운영 pm2(api)는 ecosystem 에서 CRAWLER_MATCHER_IN_API=0 + crawler-matcher-worker 사용.
# CRAWLER_MATCHER_IN_API=0
# ── crawler-matcher-worker (pnpm start:matcher-worker) ────────────────
# 주기 매칭(ms). 0 이면 주기 없음·기동 1회만.
# 비프로덕션·미설정: 약 7분(420000) 기본. 운영 pm2(ecosystem)도 동일 기본.
# CRAWLER_MATCHER_TICK_MS=420000
# 워커 기동 후 manual 매칭 1회 큐 (비프로덕션 기본 on). 끄기: RUN_CRAWLER_MATCHER_ON_BOOT=0
# RUN_ODDS_INGEST_ON_BOOT=1 이고 아래 체인=1 이면: 첫 기동 ODDS(boot-odds) 완료 후에만 큐잉(타이머·지연 대신 순서 보장). 끄면 예전 타이머:
# CRAWLER_MATCHER_BOOT_CHAIN_AFTER_FIRST_ODDS=1
# RUN_CRAWLER_MATCHER_ON_BOOT_DELAY_MS=4000
# loose: HQ 리그/팀 확정 없이 sport 내 리그 버킷(퍼지)+팀명으로 매칭. 자동 점수·간격 조절:
# CRAWLER_MATCHER_LOOSE=1
# CRAWLER_MATCHER_LOOSE_AUTO_MIN=76
# CRAWLER_MATCHER_LOOSE_GAP=6
