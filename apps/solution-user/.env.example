# 로컬 개발 (next dev) — .env.local 에 복사 후 수정
NEXT_PUBLIC_API_URL=http://localhost:4001/api
# 로컬에선 끄거나 생략 (true 이면 http://localhost:3002/api 로 가서 404)
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=

# 도메인 구조
#   user  = <solution-domain>
#   admin = mod.<solution-domain>
#   agent = agent.<solution-domain>
#   super = mod.tozinosolution.com

# IP 로만 접속하는데 DB 에는 nexus001.vip 만 등록된 경우
# NEXT_PUBLIC_PLATFORM_DOMAIN=nexus001.vip

# 스포츠 탭 OddsHost 프록시 — apps/api 의 ODDSHOST_PROXY_SECRET 과 동일 문자열 (빌드에 포함됨)
# NEXT_PUBLIC_ODDSHOST_PROXY_SECRET=

# 스포츠 로비: false = 운영(스냅샷만 카드에 표시, 테스트 UI 숨김). true = 데모·API 테스트·진단. 미설정 시 dev=테스트 / build=운영
# NEXT_PUBLIC_SPORTS_OPERATOR_TOOLS=

# ── 운영 빌드(.env.production) 예시 — docs/DEPLOY_PRODUCTION.md 참고
# Cloudflare tunnel 처럼 API를 별도 도메인으로 둘 때
# NEXT_PUBLIC_API_URL=https://apisgate.org/api
# nginx 로 user/admin/agent 각 도메인에서 /api 를 프록시할 때
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=true
# NEXT_PUBLIC_ODDSHOST_PROXY_SECRET=<apps/api/.env 의 ODDSHOST_PROXY_SECRET 과 동일>
