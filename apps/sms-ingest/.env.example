# 메인 API와 동일 DB
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/tosino?schema=public"
SMS_INGEST_PORT=4050
# 비우거나 생략하면 비밀 검증 없음(로컬·테스트용). 운영 시에만 긴 랜덤 문자열 설정 권장.
# SMS_INGEST_SECRET=

# --- 모바일(외부망)에서 접속할 때 ---
# 로컬 4050은 LTE/Wi-Fi 다른 기기에서 직접 못 엽니다. cloudflared로 HTTPS 터널을 띄운 뒤
# Flutter 앱의 "수신 서버 URL"에 다음 형태로 넣으세요 (끝에 /webhook/sms 필수):
#   https://xxxx.trycloudflare.com/webhook/sms   (빠른 터널, 실행마다 호스트 변경)
#   https://sms-ingest.당신도메인/webhook/sms     (Named Tunnel + 고정 호스트명)
#
# 한 터미널에 ingest + 터널 동시:  pnpm dev:sms-ingest:public
# 또는 분리: 터미널1 pnpm dev:sms-ingest  /  터미널2 pnpm tunnel:sms-ingest
# 예시 설정: scripts/cloudflared-sms-ingest.config.example.yml
#
# nginx 배포 시( deploy/nginx/nexus001.vip.conf ): 외부 URL은
#   https://<도메인>/webhook/sms  (PM2 sms-ingest 가 127.0.0.1:4050 에 떠 있어야 함)
