# ── score-crawler ──────────────────────────────────────────────────────────
# Livesport Korea 기반 스포츠 결과 수집기 (MVP) 설정.
# sqlite 테스트 기본값. 나중에 mysql/mariadb 이관 시 DB_URL 만 바꾸면 된다.

# 저장소 (현재는 sqlite 파일 경로만 지원)
DB_URL=sqlite:///./score-crawler.db

# 기본 source site key (sport_mappings / crawler_*_raw 테이블의 source_site 에 그대로 기록)
SOURCE_SITE=livesport

# odds-api.io 기준 provider key. 매핑 테이블의 provider_name.
PROVIDER_NAME=odds-api.io

# 동작 옵션 (CLI 인자로도 오버라이드 가능)
ONLY_SUPPORTED_SPORTS=true
# 0 = 지원(primary) 종목 전부 순회. 가벼운 스모크는 LIMIT_PAGES=3 등
LIMIT_PAGES=0
# 종목 페이지당 수집 경기 상한 (aiscore: 스크롤 합산 후 잘라냄)
LIMIT_ROWS_PER_PAGE=10000
# aiscore 전용: 초기 워밍 스크롤 / 가상 리스트 수집 라운드
# SCROLL_PASSES=12
# SCROLL_COLLECT_ROUNDS=160
# sqlite→Nest raw 푸시 시 한 번에 올릴 최대 건수(최신 fetched_at 기준)
# BACKEND_PUSH_RAW_MAX=4000
HEADLESS=true

# 브라우저 타임아웃/대기 (ms)
NAV_TIMEOUT_MS=30000
WAIT_AFTER_LOAD_MS=1500

# 주기 실행 (true 면 --loop 과 같은 효과)
LOOP=false
# 루프 시 사이클 간격(초). 기본 420(약 7분) — 브라우저·네트워크 부하 완화
INTERVAL_SECONDS=420

# 사이클 시작마다 livesport 홈 헬스체크 여부
SKIP_HEALTHCHECK=false

# 국기/팀 로고를 로컬 캐시에 저장할 때 DB 에 넣는 공개 URL (상대 /assets/... 대신 https://... 선호)
# run.py 가 상위 `apps/api/.env` 를 먼저 읽는다. API 의 PUBLIC_API_URL(또는 ASSETS_PUBLIC_BASE) 로 절대 URL 이 된다.
# ASSETS_PUBLIC_BASE=
# PUBLIC_API_URL 는 보통 api/.env 에만 두면 됨.

# ── 백엔드 ingest (사이클 끝에 sqlite → Nest Postgres CrawlerRaw* 로 전송) ───────
# 비어 있으면 ingest 생략 → 슈퍼어드민 raw 합계 0 이 정상.
# URL 은 global prefix 포함: …/api 까지 (예: http://127.0.0.1:4001/api)
BACKEND_BASE_URL=http://127.0.0.1:4001/api
# Nest apps/api/.env 의 ODDS_API_INTEGRATION_KEYS(콤마 구분) 중 하나와 동일 문자열
BACKEND_INTEGRATION_KEY=
