NEXT_PUBLIC_API_URL=http://localhost:4001/api
# 시드 후 기본 솔루션 어드민: platform@tosino.local / Admin123! (prisma/seed.ts)
# mod.<solution-domain> 에서 host 기준으로 자동 로그인 플랫폼이 잡힙니다.
# 로컬 파일/미리보기처럼 host 해석이 어려울 때: platformId 또는 slug(시드 데모는 demo)
# NEXT_PUBLIC_LOGIN_PLATFORM_ID=
# NEXT_PUBLIC_LOGIN_PLATFORM_SLUG=demo
# nginx 로 /api 프록시를 붙인 운영이면 아래를 함께 사용 가능
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=true
